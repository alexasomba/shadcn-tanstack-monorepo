{
  "name": "start-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "setup": "vp install && vp run --filter data-ops build && node scripts/setup-git-workflow.mjs",
    "prepare": "vp config && node scripts/setup-git-workflow.mjs",
    "git:setup": "node scripts/setup-git-workflow.mjs",
    "worktree:create": "node scripts/worktree.mjs create",
    "worktree:merge": "node scripts/worktree.mjs merge",
    "worktree:cleanup": "node scripts/worktree.mjs cleanup",
    "worktree:list": "node scripts/worktree.mjs list",
    "cache:clean": "vp cache clean"
  },
  "dependencies": {
    "@opencoredev/domain-sdk": "catalog:"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "catalog:",
    "@tanstack/eslint-plugin-query": "catalog:",
    "@tanstack/eslint-plugin-router": "catalog:",
    "eslint-plugin-drizzle": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-no-instanceof": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-sonarjs": "catalog:",
    "eslint-plugin-zod": "catalog:",
    "eslint-plugin-zod-openapi": "catalog:",
    "typescript": "6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.13.0"
}
