{
  "name": "data-service",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "cf-typegen": "wrangler types worker-configuration.d.ts --env-interface CloudflareBindings --include-runtime false",
    "build": "pnpm run cf-typegen",
    "deploy": "vp run build && wrangler deploy --minify",
    "deploy:preview": "vp run build && wrangler versions upload"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "catalog:",
    "@hono/zod-openapi": "^1.4.0",
    "better-auth": "catalog:",
    "data-ops": "workspace:*",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "wrangler": "catalog:"
  }
}
