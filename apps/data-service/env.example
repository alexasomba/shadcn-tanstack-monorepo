# Generate: openssl rand -base64 32 (use the same secret as web apps when sharing sessions/D1)
BETTER_AUTH_SECRET=replace-with-32-plus-char-secret
BETTER_AUTH_URL=http://127.0.0.1:8302

# --- Notifications (better-notify) — primary: OneSignal ---
# App ID is non-secret; REST API key is a secret (.dev.vars / wrangler secret put).
# Without both, getNotifyClient runs dry-run (mock transport, zero outbound HTTP).
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
# Optional: force dry-run even when OneSignal is set (local debugging)
# NOTIFY_DRY_RUN=1
# Optional Discord for platformAlert catalog route
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional secondary mailer fallback (onboarding only if OneSignal send throws)
# RESEND_API_KEY=re_...
# EMAIL_FROM=App <noreply@example.com>

# --- Custom domains (domain-sdk → Cloudflare for SaaS) ---
# Product model: custom hostname → organization.slug (same tenant as vanity host).
# - Platform vanity: {slug}.PLATFORM_BASE_DOMAIN  (e.g. acme.app.example.com)
# - Custom domain:   customer.com in `domains` table → that org's slug
# Resolve: GET /tenant/resolve?host=...  (user-web also resolves via local D1 + Cache API)
# Deploy checklist: docs/cloudflare-for-saas.md
#
# Secret:
# CLOUDFLARE_API_TOKEN=
# Non-secret vars:
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_CNAME_TARGET=customers.example.com
# PLATFORM_BASE_DOMAIN=app.example.com
# Local/e2e without CF: DOMAIN_SDK_MODE=memory
