# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-32-plus-char-secret
# Public origin of this app (auth handler base URL)
BETTER_AUTH_URL=http://127.0.0.1:8300
# Optional public site URL for sitemap / llms / robots
# VITE_APP_URL=https://example.com
# Optional comma-separated CSRF allowlist (defaults include monorepo dev ports)
# BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:8300,http://127.0.0.1:8301
# Client override only if auth API is on another host
# VITE_BETTER_AUTH_URL=http://127.0.0.1:8300

# --- Multi-tenant host → organization.slug ---
# Vanity: {slug}.PLATFORM_BASE_DOMAIN  |  Custom: active row in `domains`
# Resolved in root beforeLoad (local D1). Leave unset for localhost-only dev.
# PLATFORM_BASE_DOMAIN=app.example.com

# --- Transactional email / push (better-notify → OneSignal) ---
# Auth verify/reset/invite/OTP use getNotifyClient. Same keys as data-service when this Worker sends mail.
# Put secrets in .dev.vars (local) or `wrangler secret put` (remote) — not in wrangler.jsonc vars.
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
# Optional dry-run: mock transports, no provider HTTP (saves CPU ms)
# NOTIFY_DRY_RUN=1
# Optional Resend fallback only for workflow/mailer paths (not primary)
# RESEND_API_KEY=re_...
# EMAIL_FROM=App <noreply@example.com>

# Paystack billing (better-auth-paystack) — optional for plan listing; required for live checkout/webhooks
# PAYSTACK_SECRET_KEY=sk_test_...
# PAYSTACK_WEBHOOK_SECRET=sk_test_...  # usually same as secret key
# Optional native plan codes (override local-managed plans):
# PAYSTACK_PLAN_PRO=PLN_xxx
# PAYSTACK_PLAN_PRO_YEARLY=PLN_xxx
# PAYSTACK_PLAN_BUSINESS=PLN_xxx
# PAYSTACK_PLAN_BUSINESS_YEARLY=PLN_xxx
# BETTER_AUTH_APP_NAME=Starter
