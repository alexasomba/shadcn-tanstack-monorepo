{
  "name": "user-web-app",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vp dev --port 8300 --host 127.0.0.1\"",
    "generate-routes": "tsr generate",
    "content-collections:build": "npx @content-collections/cli build",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "build": "pnpm types && vp build && mkdir -p .output/server && cp instrument.server.mjs .output/server",
    "types": "wrangler types worker-configuration.d.ts --include-runtime false",
    "preview": "vp preview --port 8300",
    "test": "vitest run",
    "lint": "vp lint",
    "format": "vp fmt",
    "check": "vp check",
    "deploy": "vp run build && wrangler deploy",
    "deploy:preview": "vp run build && wrangler versions upload",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs"
  },
  "dependencies": {
    "@alexasomba/better-auth-paystack": "^3.0.0",
