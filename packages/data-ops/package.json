{
  "name": "data-ops",
  "version": "0.0.1",
  "private": true,
  "files": [
    "dist",
    "src",
    "drizzle.config.ts",
    "wrangler.jsonc"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/drizzle/schema/core.ts",
      "import": "./src/drizzle/schema/core.ts",
      "default": "./src/drizzle/schema/core.ts"
    },
    "./auth-schema": {
      "types": "./src/drizzle/schema/auth.ts",
      "import": "./src/drizzle/schema/auth.ts",
      "default": "./src/drizzle/schema/auth.ts"
    },
    "./database/setup": {
      "types": "./src/database/setup.ts",
      "import": "./src/database/setup.ts",
      "default": "./src/database/setup.ts"
    },
    "./database/seed": {
      "types": "./src/database/seed.ts",
      "import": "./src/database/seed.ts",
      "default": "./src/database/seed.ts"
    },
    "./auth": {
      "types": "./src/auth/create-auth.ts",
      "import": "./src/auth/create-auth.ts",
      "default": "./src/auth/create-auth.ts"
    },
    "./auth/*": {
      "types": "./src/auth/*.ts",
      "import": "./src/auth/*.ts",
      "default": "./src/auth/*.ts"
    },
    "./queries/*": {
      "types": "./src/queries/*.ts",
      "import": "./src/queries/*.ts",
      "default": "./src/queries/*.ts"
    },
    "./zod-schema/*": {
      "types": "./src/zod/schema/*.ts",
      "import": "./src/zod/schema/*.ts",
      "default": "./src/zod/schema/*.ts"
    },
    "./email/*": {
      "types": "./src/email/*.ts",
      "import": "./src/email/*.ts",
      "default": "./src/email/*.ts"
    },
    "./seo/*": {
      "types": "./src/seo/*.ts",
      "import": "./src/seo/*.ts",
      "default": "./src/seo/*.ts"
    },
    "./r2": {
      "types": "./src/r2.ts",
      "import": "./src/r2.ts",
      "default": "./src/r2.ts"
    },
    "./workflows": {
      "types": "./src/workflows/onboarding.ts",
      "import": "./src/workflows/onboarding.ts",
      "default": "./src/workflows/onboarding.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack && tsc --noEmit",
    "pack": "vp pack",
    "typecheck": "tsc --noEmit",
    "auth:generate": "auth generate --config ./src/auth/auth.ts --output ./src/drizzle/schema/auth.ts --yes",
    "auth:info": "auth info --config ./src/auth/auth.ts",
    "auth:secret": "auth secret",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:migrate:local": "wrangler d1 migrations apply app-db --cwd ../../apps/user-web --config wrangler.jsonc --local",
    "db:migrate:remote": "wrangler d1 migrations apply app-db --config wrangler.jsonc --remote",
    "db:query:local": "wrangler d1 execute app-db --cwd ../../apps/user-web --config wrangler.jsonc --local --command",
    "db:query:remote": "wrangler d1 execute app-db --config wrangler.jsonc --remote --command"
  },
  "dependencies": {
    "@alexasomba/better-auth-paystack": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@better-auth/api-key": "1.7.0-rc.1",
    "@better-auth/drizzle-adapter": "catalog:",
    "@better-auth/passkey": "catalog:",
    "@betternotify/core": "catalog:",
    "@betternotify/discord": "catalog:",
    "@betternotify/email": "catalog:",
    "@betternotify/onesignal": "catalog:",
    "@betternotify/push": "catalog:",
    "@marinedotsh/better-auth-referral": "catalog:",
    "@workspace/result": "workspace:*",
    "better-auth": "catalog:",
    "better-inbox": "catalog:",
    "better-result": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "auth": "catalog:",
    "drizzle-kit": "catalog:",
    "drizzle-seed": "^0.3.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "catalog:"
  }
}
