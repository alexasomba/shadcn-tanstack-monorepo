#!/usr/bin/env sh
# Policy: multi-agent worktrees (AGENTS.md + setup-git-workflow.mjs)
# Allow: preview | detached HEAD (worktree). Block: main | feature branches.

branch=$(git branch --show-current 2>/dev/null || true)

if [ -z "$branch" ]; then
  # Detached HEAD — expected in .worktrees/*
  exit 0
fi

if [ "$branch" = "preview" ]; then
  exit 0
fi

if [ "$branch" = "main" ]; then
  echo "ERROR: Do not commit on main (multi-agent integration is preview)."
  echo "  Work:  pnpm worktree:create <type>-<topic>_<purpose>"
  echo "  Docs:  AGENTS.md → Multi-agent–safe Git"
  exit 1
fi

echo "ERROR: Feature branch '$branch' is not allowed (multi-agent safety)."
echo "  Use a detached worktree so agents do not share a branch tip:"
echo "  pnpm worktree:create <type>-<topic>_<purpose>"
echo "  Docs: AGENTS.md → Multi-agent–safe Git"
exit 1
vp staged
