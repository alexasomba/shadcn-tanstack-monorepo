#!/usr/bin/env sh
# Policy: multi-agent worktrees (AGENTS.md + setup-git-workflow.mjs)
# Allow push: preview | main | tags. Block: feature-branch refs.

blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$local_ref" ] && continue
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi
  case "$remote_ref" in
    refs/heads/preview | refs/heads/main | refs/tags/*) ;;
    *)
      echo "ERROR: Refusing to push '$remote_ref' (multi-agent safety)."
      echo "  Integrate via: pnpm worktree:merge <name> --message \"feat: …\""
      echo "  Docs: AGENTS.md → Multi-agent–safe Git"
      blocked=1
      ;;
  esac
done

exit $blocked
