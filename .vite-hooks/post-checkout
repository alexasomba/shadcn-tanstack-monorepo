#!/usr/bin/env sh
# Policy: multi-agent worktrees (AGENTS.md + setup-git-workflow.mjs)
# Allow: preview | main | detached. Block: feature-branch checkout.

prev_head="$1"
new_head="$2"
branch_checkout="$3"

if [ "$branch_checkout" != "1" ]; then
  exit 0
fi

# worktree:merge sets this while integrating onto preview
if [ -n "${LTP_AUTOMATED_MERGE-}" ] || [ -n "${LTP_ALLOW_BRANCH-}" ]; then
  exit 0
fi

branch=$(git branch --show-current 2>/dev/null || true)

if [ -z "$branch" ]; then
  exit 0
fi

if [ "$branch" = "preview" ] || [ "$branch" = "main" ]; then
  exit 0
fi

echo "ERROR: Feature branch '$branch' is not allowed (multi-agent safety)."
echo "  Agents use detached .worktrees/*, not long-lived branches."
echo "  pnpm worktree:create <type>-<topic>_<purpose>"
echo "  Override: LTP_ALLOW_BRANCH=1 git checkout <branch>"
echo "  Docs: AGENTS.md → Multi-agent–safe Git"
echo "Returning to preview…"
git checkout preview --quiet 2>/dev/null || git switch preview --quiet 2>/dev/null || true
exit 1
