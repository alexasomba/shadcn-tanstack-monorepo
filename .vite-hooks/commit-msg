#!/usr/bin/env sh

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Remove comments starting with # (git default comments)
commit_msg_clean=$(echo "$commit_msg" | grep -v '^#')

# 1. Check <type>: message structure
if ! echo "$commit_msg_clean" | grep -Eq "^(feat|fix|chore|docs|refactor|test|style|ci|perf)(\([a-z0-9_-]+\))?: .+$"; then
  echo "ERROR: Commit message must start with '<type>: <message>'"
  echo "Allowed types: feat, fix, chore, docs, refactor, test, style, ci, perf"
  exit 1
fi

# Extract type
commit_type=$(echo "$commit_msg_clean" | grep -Eo "^[a-z]+" | head -n 1)

# 2. Check Fixes #123 suffix for meaningful types (feat, fix, refactor, perf)
if echo "$commit_type" | grep -Eq "^(feat|fix|refactor|perf)$"; then
  if ! echo "$commit_msg_clean" | grep -Eq "Fixes #[0-9]+"; then
    echo "ERROR: Commits of type '$commit_type' must contain 'Fixes #<issue-number>'"
    echo "Create an issue first with GitHub CLI, then reference it in the commit message."
    echo "Example:"
    echo "  gh issue create"
    echo "  git commit -m \"$commit_type: your message Fixes #123\""
    exit 1
  fi
fi
