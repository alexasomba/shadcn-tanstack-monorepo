#!/usr/bin/env sh
# Policy: multi-agent worktrees (AGENTS.md + setup-git-workflow.mjs)
# Do not rewrite shared integration/release history under concurrent agents.

branch=$(git branch --show-current 2>/dev/null || true)

if [ "$branch" = "preview" ] || [ "$branch" = "main" ]; then
  echo "ERROR: Do not rebase shared branch '$branch' (multi-agent safety)."
  echo "  Docs: AGENTS.md → Multi-agent–safe Git"
  exit 1
fi

exit 0
